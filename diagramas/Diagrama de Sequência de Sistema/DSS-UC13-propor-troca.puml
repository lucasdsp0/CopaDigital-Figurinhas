@startuml DSS-UC13-propor-troca
title DSS - UC-13: Propor Troca Entre Usuarios\nSistema FigurinhasCopa Digital (Visao de Sistema)

skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam backgroundColor #FAFAFA
skinparam sequence {
  ArrowColor #2C3E50
  ActorBorderColor #2C3E50
  ActorBackgroundColor #D5E8D4
  LifeLineBorderColor #2980B9
  LifeLineBackgroundColor #EBF5FB
  ParticipantBorderColor #2980B9
  ParticipantBackgroundColor #EBF5FB
  BoxBackgroundColor #F2F3F4
  BoxBorderColor #BDC3C7
}

note over Sistema
  <<Sistema>>
  FigurinhasCopa Digital
  (caixa preta)
end note

actor "Usuario\n(Proponente)" as U
actor "Usuario\n(Dono da Oferta)" as D
participant "Sistema\nFigurinhasCopa" as Sistema

U -> Sistema : buscarOfertasNoMarketplace(filtros)
activate Sistema
Sistema --> U : exibirOfertas(listaOfertas)
deactivate Sistema

U -> Sistema : visualizarOferta(ofertaId)
activate Sistema
Sistema --> U : exibirDetalhesOferta(figurinha, dono, condicoes)
deactivate Sistema

U -> Sistema : selecionarMinhaFigurinhaParaTroca(minhaFigurinhaId)
activate Sistema
Sistema --> U : exibirConfirmacaoProposta(resumoTroca)
deactivate Sistema

U -> Sistema : confirmarPropostaTroca(ofertaId, minhaFigurinhaId)
activate Sistema

alt Proposta valida
  Sistema --> U : propostaEnviada(propostaId, status: "pendente")
  Sistema ->> D : notificarNovaProposta("Nova proposta de troca recebida!")
else Figurinha indisponivel
  Sistema --> U : notificarErro("Figurinha nao disponivel para troca.")
end

deactivate Sistema

@enduml
